{"frames":[{"func":"knitr::kable(tibble::tribble(~Slot, ~Type, ~Contents, \"ensemble\", \n    \"named list\", \"One entry per fitted model. Each entry contains the sub-slots below.\", \n    \"ensemble[[m]]$stan_fit\", \"stanfit (rstan)\", \"Raw CmdStanMCMC posterior. Use posterior::as_draws_*() to extract. NULL if model failed to compile or sample.\", \n    \"ensemble[[m]]$loo\", \"loo object\", \"PSIS-LOO result. Plot with plot(); compare across models with loo::loo_compare().\",  ...","file":"","line_number":0,"end_line_number":0,"character_number":0,"end_character_number":0},{"func":"gsub(\"^\\\\s+|(?<!\\\\\\\\)\\\\s+$\", \"\", x, perl = TRUE)","file":"","line_number":0,"end_line_number":0,"character_number":0,"end_character_number":0}],"message":"Error in gsub(\"^\\\\s+|(?<!\\\\\\\\)\\\\s+$\", \"\", x, perl = TRUE) : \n  input string 35 is invalid UTF-8\n"}