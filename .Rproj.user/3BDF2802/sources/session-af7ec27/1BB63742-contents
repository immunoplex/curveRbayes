# ============================================================================
# 5. Grid predictions match reference — per plate
# ============================================================================

test_that("grid predicted_response matches reference for each curve_id", {
  skip_if_not(cmdstanr_available())
  skip_if_not(file.exists(ref_path()))

  ref    <- readRDS(ref_path())
  result <- run_bayes_curve123()

  for (cid in EXPECTED_CIDS) {
    cr     <- result$plates[[cid]]
    ref_cr <- ref$plates[[cid]]

    expect_equal(nrow(cr$grid), nrow(ref_cr$grid),
                 info = paste("Grid row count differs for curve_id", cid))
    expect_equal(cr$grid$predicted_response,
                 ref_cr$grid$predicted_response,
                 tolerance = TOL_RESPONSE,
                 info = paste("Grid predicted_response shifted for curve_id", cid))
  }
})

test_that("grid predicted_concentration matches reference for each curve_id", {
  skip_if_not(cmdstanr_available())
  skip_if_not(file.exists(ref_path()))

  ref    <- readRDS(ref_path())
  result <- run_bayes_curve123()

  for (cid in EXPECTED_CIDS) {
    cr     <- result$plates[[cid]]
    ref_cr <- ref$plates[[cid]]

    ref_pc <- ref_cr$grid$predicted_concentration
    cur_pc <- cr$grid$predicted_concentration
    both_ok <- is.finite(ref_pc) & is.finite(cur_pc)

    if (any(both_ok)) {
      expect_equal(cur_pc[both_ok], ref_pc[both_ok],
                   tolerance = TOL_CONC,
                   info = paste("Predicted conc shifted for curve_id", cid))
    }
    expect_equal(is.na(cur_pc), is.na(ref_pc),
                 info = paste("NA pattern changed for curve_id", cid))
  }
})


# ============================================================================
# 6. Sample predictions match reference — per plate
# ============================================================================

test_that("sample predictions match reference for each curve_id", {
  skip_if_not(cmdstanr_available())
  skip_if_not(file.exists(ref_path()))

  ref    <- readRDS(ref_path())
  result <- run_bayes_curve123()

  for (cid in EXPECTED_CIDS) {
    cr     <- result$plates[[cid]]
    ref_cr <- ref$plates[[cid]]

    # Skip plates where reference has no samples
    if (is.null(ref_cr$samples)) {
      expect_null(cr$samples,
                  info = paste("Samples appeared for curve_id", cid,
                               "but reference has none"))
      next
    }

    expect_equal(nrow(cr$samples), nrow(ref_cr$samples),
                 info = paste("Sample row count differs for curve_id", cid))

    # predicted_log10_concentration
    if ("predicted_log10_concentration" %in% names(ref_cr$samples)) {
      ref_plc <- ref_cr$samples$predicted_log10_concentration
      cur_plc <- cr$samples$predicted_log10_concentration
      both_ok <- is.finite(ref_plc) & is.finite(cur_plc)
      if (any(both_ok)) {
        expect_equal(cur_plc[both_ok], ref_plc[both_ok],
                     tolerance = TOL_CONC,
                     info = paste("log10 conc shifted for curve_id", cid))
      }
    }

    # final_concentration
    if ("final_concentration" %in% names(ref_cr$samples)) {
      ref_fc <- ref_cr$samples$final_concentration
      cur_fc <- cr$samples$final_concentration
      both_ok <- is.finite(ref_fc) & is.finite(cur_fc) & ref_fc > 0
      if (any(both_ok)) {
        rel_diff <- abs(cur_fc[both_ok] - ref_fc[both_ok]) / ref_fc[both_ok]
        expect_true(all(rel_diff < TOL_SAMPLE_REL),
                    info = sprintf("curve_id %s: max relative diff: %.6f",
                                   cid, max(rel_diff)))
      }
    }
  }
})


