    expect_equal(cr$meta$curve_id,           ref_cr$meta$curve_id,
                 info = paste("curve_id differs for curve_id", cid))
    expect_equal(cr$meta$response_var,       ref_cr$meta$response_var,
                 info = paste("response_var differs for curve_id", cid))
    expect_equal(cr$meta$is_log_response,    ref_cr$meta$is_log_response,
                 info = paste("is_log_response differs for curve_id", cid))
    expect_equal(cr$meta$is_log_independent, ref_cr$meta$is_log_independent,
