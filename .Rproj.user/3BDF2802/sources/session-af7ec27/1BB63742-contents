})


# ============================================================================
# 8. Ensemble convergence pattern — per plate
# ============================================================================

test_that("ensemble convergence pattern matches reference for each curve_id", {
  skip_if_not(cmdstanr_available())
  skip_if_not(file.exists(ref_path()))

  ref    <- readRDS(ref_path())
  result <- run_bayes_curve123()

  for (cid in EXPECTED_CIDS) {
    cr     <- result$plates[[cid]]
    ref_cr <- ref$plates[[cid]]

    ref_conv <- vapply(ref_cr$ensemble,
                       function(e) isTRUE(e$converged), logical(1))
    cur_conv <- vapply(cr$ensemble,
                       function(e) isTRUE(e$converged), logical(1))

    expect_equal(sort(names(ref_conv)), sort(names(cur_conv)),
                 info = paste("Model names differ for curve_id", cid))

    for (nm in names(ref_conv)) {
      expect_equal(cur_conv[[nm]], ref_conv[[nm]],
                   info = paste("Convergence changed for", nm,
                                "on curve_id", cid))
    }
  }
})


# ============================================================================
# 9. Structural invariants — per plate
# ============================================================================

test_that("grid predicted_response is monotonically non-decreasing", {
  skip_if_not(cmdstanr_available())

  result <- run_bayes_curve123()

  for (cid in EXPECTED_CIDS) {
    y <- result$plates[[cid]]$grid$predicted_response
    if (all(is.finite(y))) {
      expect_true(all(diff(y) >= -0.01),
                  info = paste("Monotonicity violated for curve_id", cid))
    }
  }
})

test_that("pcov_pass is consistent with pcov < cv_x_max", {
  skip_if_not(cmdstanr_available())

  result <- run_bayes_curve123()

  for (cid in EXPECTED_CIDS) {
    grid <- result$plates[[cid]]$grid
    finite_pcov <- !is.na(grid$pcov)
    if (any(finite_pcov)) {
      expected_pass <- grid$pcov < 150
      expect_equal(grid$pcov_pass[finite_pcov],
                   expected_pass[finite_pcov],
                   info = paste("pcov_pass inconsistent for curve_id", cid))
    }
  }
})

test_that("summary_table_bayes returns one row per curve_id", {
  skip_if_not(cmdstanr_available())

  result <- run_bayes_curve123()
  tbl <- curveRbayes::summary_table_bayes(result)

  expect_equal(nrow(tbl), 3)
  expect_true("curve_id" %in% names(tbl))
  expect_true("a_mean" %in% names(tbl))
  expect_false("antigen" %in% names(tbl))
  expect_equal(sort(tbl$curve_id), EXPECTED_CIDS)
})

test_that("all plates have expected grid columns", {
  skip_if_not(cmdstanr_available())

  result <- run_bayes_curve123()

  grid_cols <- c("log10_concentration", "concentration", "x_fit",
                 "predicted_response", "ci_lower", "ci_upper",
                 "predicted_concentration", "se_concentration",
                 "pcov", "pcov_pass")

  for (cid in EXPECTED_CIDS) {
    grid <- result$plates[[cid]]$grid
    for (col in grid_cols) {
      expect_true(col %in% names(grid),
                  info = paste("Missing", col, "in grid for curve_id", cid))
    }
  }
})
