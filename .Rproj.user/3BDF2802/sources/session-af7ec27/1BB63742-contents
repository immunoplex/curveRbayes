# =============================================================================
# test-reference-bayes.R
#
# Regression test: fit_calibration_bayes() on bead_assay_example
# curve_ids 1,2,3 versus a frozen reference RDS snapshot.
#
# REFACTORED for multiplate return format: fit_calibration_bayes() now
# returns calibration_result_multiplate with $plates named list, where
# each plate is a calibration_result with $grid, $samples, $ensemble,
# $selection, $meta.  This matches the curveRfreq multiplate structure.
#
# Bayesian tolerances are wider than frequentist due to MCMC noise.
#
# Generate the reference with:
#   Rscript data-raw/generate_reference_bayes.R
# =============================================================================

library(curveRcore)

# ---- Tolerance constants ----
TOL_PARAM_MEAN <- 0.05
TOL_PARAM_SD   <- 0.05
TOL_RESPONSE   <- 0.02
TOL_CONC       <- 0.05
TOL_PCOV       <- 2.0
TOL_SAMPLE_REL <- 0.30

# ---- Expected curve_ids ----
EXPECTED_CIDS <- c("1", "2", "3")


# ============================================================================
# Helpers
# ============================================================================

cmdstanr_available <- function() {
  requireNamespace("cmdstanr", quietly = TRUE) &&
    tryCatch({ cmdstanr::cmdstan_version(); TRUE }, error = function(e) FALSE)
}

ref_path <- function() {
  testthat::test_path("fixtures", "reference_bayes_curve123.rds")
}

run_bayes_curve123 <- function() {
  data("bead_assay_example", package = "curveRcore", envir = environment())

  std_raw <- bead_assay_example$standards[
    bead_assay_example$standards$curve_id %in% c(1, 2, 3), ]

  prepped <- curveRcore::preprocess_standards(
    data                 = std_raw,
    antigen_settings     = list(standard_curve_concentration = 10000),
    response_variable    = "mfi",
    independent_variable = "concentration",
    is_log_response      = TRUE,
    is_log_independent   = TRUE,
    apply_prozone        = TRUE
  )

  samples <- bead_assay_example$samples[
    bead_assay_example$samples$curve_id %in% c(1, 2, 3), ]

  curveRbayes::fit_calibration_bayes(
    standards          = prepped$data,
    samples            = samples,
    response_var       = "mfi",
    model_names        = c("logistic4", "gompertz4"),
    is_log_response    = TRUE,
    is_log_independent = TRUE,
    std_curve_conc     = 10000,
    chains             = 4,
    warmup             = 1000,
    sampling           = 1000,
    adapt_delta        = 0.9,
    seed               = 20260529,
    run_loo            = TRUE,
    n_draws_predict    = 500,
    verbose            = FALSE
  )
}


# ============================================================================
# 0. Smoke test
# ============================================================================

test_that("fit_calibration_bayes runs on curve_ids 1,2,3 without error", {
  skip_if_not(cmdstanr_available(), "cmdstanr/CmdStan not available")

  result <- run_bayes_curve123()

  expect_s3_class(result, "calibration_result_multiplate")
  expect_equal(length(result$plates), 3)
  expect_equal(sort(names(result$plates)), EXPECTED_CIDS)

  # Spot-check one plate
  cr1 <- result$plates[["1"]]
  expect_s3_class(cr1, "calibration_result")
  expect_equal(cr1$meta$method, "bayesian")
  expect_equal(cr1$meta$curve_id, "1")
})


# ============================================================================
# 1. Reference file
# ============================================================================

test_that("reference RDS file exists", {
  skip_if_not(cmdstanr_available())
  skip_if_not(file.exists(ref_path()),
              "Reference not found. Run: Rscript data-raw/generate_reference_bayes.R")

  ref <- readRDS(ref_path())
  expect_s3_class(ref, "calibration_result_multiplate")
  expect_equal(length(ref$plates), 3)

  ref_cr1 <- ref$plates[["1"]]
  expect_s3_class(ref_cr1, "calibration_result")
  expect_equal(ref_cr1$meta$method, "bayesian")
})


# ============================================================================
# 2. Model selection — per plate
# ============================================================================

test_that("best model matches reference for each curve_id", {
  skip_if_not(cmdstanr_available())
  skip_if_not(file.exists(ref_path()))

  ref    <- readRDS(ref_path())
  result <- run_bayes_curve123()

  for (cid in EXPECTED_CIDS) {
    expect_equal(
      result$plates[[cid]]$selection$best_model_name,
      ref$plates[[cid]]$selection$best_model_name,
      info = paste("Best model selection changed for curve_id", cid))
  }
})


# ============================================================================
# 3. Parameter posterior means match reference — per plate
# ============================================================================

test_that("posterior parameter means match reference for each curve_id", {
  skip_if_not(cmdstanr_available())
  skip_if_not(file.exists(ref_path()))

  ref    <- readRDS(ref_path())
  result <- run_bayes_curve123()

  for (cid in EXPECTED_CIDS) {
    cr     <- result$plates[[cid]]
    ref_cr <- ref$plates[[cid]]
    best   <- cr$selection$best_model_name

    cur_params <- cr$ensemble[[best]]$parameters
    ref_params <- ref_cr$ensemble[[best]]$parameters

    expect_false(is.null(ref_params),
                 info = paste("Reference has no params for curve_id", cid))
    expect_false(is.null(cur_params),
                 info = paste("Result has no params for curve_id", cid))

    ref_params <- ref_params[order(ref_params$term), ]
    cur_params <- cur_params[order(cur_params$term), ]

    expect_equal(cur_params$term, ref_params$term,
                 info = paste("Parameter names differ for curve_id", cid))
    expect_equal(cur_params$mean, ref_params$mean,
                 tolerance = TOL_PARAM_MEAN,
                 info = paste("Posterior means shifted for curve_id", cid))
    expect_equal(cur_params$sd, ref_params$sd,
                 tolerance = TOL_PARAM_SD,
                 info = paste("Posterior SDs shifted for curve_id", cid))
  }
})


# ============================================================================
# 4. All curve_ids have parameters
# ============================================================================

test_that("all 3 curve_ids have posterior parameters", {
  skip_if_not(cmdstanr_available())

  result <- run_bayes_curve123()

  expect_equal(length(result$plates), 3)

  for (cid in EXPECTED_CIDS) {
    cr   <- result$plates[[cid]]
    best <- cr$selection$best_model_name
