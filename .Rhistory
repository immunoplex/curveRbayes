results <- do.call(rbind, lapply(names(fit$plates), function(cid) {
s <- fit$plates[[cid]]$samples
if (is.null(s)) return(NULL)
s
}))
if (!is.null(results) && nrow(results) > 0) {
head(results[, c("curve_id", "sampleid", "mfi",
"predicted_concentration", "final_concentration",
"se_concentration", "pcov", "pcov_pass")]) |>
knitr::kable(digits = 3,
caption = "Back-calculated concentrations (first 6 rows). predicted_concentration is on the log10(AU/mL) scale.")
} else {
cat("No sample predictions available.\n")
}
names(fit)
class(fit)
