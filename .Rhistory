"gompertz4", "loglogistic5"),
is_log_response    = study_params$is_log_response,
is_log_independent = study_params$is_log_independent,
std_curve_conc     = antigen_settings$standard_curve_concentration,
fixed_a            = NULL,
n_grid             = 200L,
grid_min_conc      = 1e-4,
chains             = 4L,
warmup             = 1000L,
sampling           = 1000L,
adapt_delta        = 0.95,
seed               = 42,
run_loo            = TRUE,
verbose            = TRUE
)
# ── Bridge: extract convenience references from multiplate structure ──
# fit_calibration_bayes() returns calibration_result_multiplate with
# $meta and $plates. The vignette uses per-model objects directly.
# Pick curve_id 1 for single-curve demonstrations
cr1 <- fit$plates[["1"]]
stopifnot("No plates returned — fit likely failed silently" = !is.null(cr1))
# The per-curve ensemble contains all fitted models
# Each entry has: $model_name, $converged, $parameters, $fit_stats,
#   $raw_fit (full bayes_fit), $eligibility, $grid
ensemble <- cr1$ensemble
# CmdStanMCMC fit and posterior draws for logistic4
cmdstan_fit_4pl <- cr1$ensemble[["logistic4"]]$raw_fit$fit
draws_4pl       <- posterior::as_draws_df(cmdstan_fit_4pl$draws())
# LOO comparison and stacking weights from the selection metadata
loo_comparison   <- fit$meta$selection$loo_comparison
stacking_weights <- fit$meta$selection$loo_weights
if (is.null(names(stacking_weights)))
names(stacking_weights) <- names(ensemble)
# Compute per-model LOO objects for Pareto-k diagnostics
loo_list <- lapply(ensemble, function(m) {
if (!is.null(m$raw_fit)) compute_loo(m$raw_fit) else NULL
})
cat("Models fitted:", paste(names(ensemble), collapse = ", "), "\n")
cat("Best model:", fit$meta$best_model, "\n")
# Assemble eligibility data frame from per-plate per-model assessments
eligibility <- do.call(rbind, lapply(names(fit$plates), function(cid) {
cr <- fit$plates[[cid]]
do.call(rbind, lapply(names(cr$ensemble), function(fam) {
elig <- cr$ensemble[[fam]]$eligibility
if (is.null(elig) || is.null(elig$gates)) return(NULL)
gates_df <- elig$gates
gates_df$model    <- fam
gates_df$curve_id <- as.integer(cid)
gates_df$eligible <- elig$eligible
gates_df
}))
}))
