set.seed(123)
# Extract 400 posterior samples for logistic4
draws_mat <- posterior::as_draws_matrix(cmdstan_fit_4pl$draws())
idx       <- sample(nrow(draws_mat), 400)
samp      <- draws_mat[idx, ]
# Plate-level parameters for curve_id = 1 are already in the draws
A <- samp[, "a[1]"]
B <- samp[, "b[1]"]
C <- samp[, "c_par[1]"]
D <- samp[, "d[1]"]
sigma_obs <- samp[, "sigma_obs"]
# Grid point: log10(1 AU/mL) = 0
x_star <- 0
# Step 1-2: forward prediction at x_star
y_tilde <- A + (D - A) / (1 + (x_star / C)^B)
# Step 3: inject Student-t noise (df = 4), then invert
eps    <- rt(length(y_tilde), df = 4) * sigma_obs
y_star <- y_tilde + eps
# Analytical inverse for logistic4:
#   x = C * ( (D - A)/(y - A) - 1 )^(1/B)
x_hat  <- C * ((D - A) / pmax(y_star - A, 1e-9) - 1)^(1 / B)
x_hat  <- x_hat[is.finite(x_hat) & x_hat > 0]
cat(sprintf(
"CDAN back-calculation at log10(x*) = %.1f  [x* = %.0f AU/mL]\n",
x_star, 10^x_star
))
cat(sprintf("  Posterior mean:  %.4f  log10(AU/mL)\n", mean(log(x_hat) / log(10))))
cat(sprintf("  Posterior SD:    %.4f  log10(AU/mL)\n", sd(log(x_hat) / log(10))))
cat(sprintf("  Back-calc CV:    %.1f%%\n",
100 * sd(x_hat) / mean(x_hat)))
# Test samples: observed MFI values for curve_ids 1–3
test_samples <- data.frame(
curve_id = c(1L, 1L, 2L, 2L, 3L, 3L),
sampleid = paste0("S", 1:6),
mfi      = c(12500, 8300, 14100, 9800, 11600, 7200)
)
# Stacked ensemble back-calculation
results <- predict_samples_bayes(
fit       = fit,
newdata   = test_samples,
use_stack = TRUE,
ci_level  = 0.95
)
unlink("vignettes/bayesian-quickstart_cache", recursive = TRUE)
# Samples were already back-calculated during fit_calibration_bayes().
